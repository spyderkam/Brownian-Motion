    "\n",
    "#from scipy.special import expit\n",
    "#Ree_ave=expit(Ree_ave)     # supress warning\n",
    "#Rg_ave=expit(Rg_ave)       # supress warning\n",
    "\n",
    "\n",
    "t = np.array(t)     # maybe call it t_arr (or not who cares)\n",
    "def exp_decay(t, τ, A, B): \n",
    "    return A*np.exp(-t/τ) + B\n",
    "\n",
    "\n",
    "###### radius of gyration plots #####\n",
    "plt.plot(t[0], Rg_ave[0], 'b', label='averaged simulated data')\n",
    "plt.plot(t, Rg_ave, 'b,')#, label='averaged simulated data')\n",
    "popt, pcov = curve_fit(exp_decay, t, Rg_ave)     \n",
    "plt.plot(t, exp_decay(t, *popt), 'r-', label=r'fit: $\\tau=%5.3f,~A=%5.3f,~B=%.3f$' % tuple(popt))\n",
    "plt.xlabel(r\"time\", fontsize=20)\n",
    "plt.ylabel(r\"$\\left\\langle{R_\\mathrm{g}}\\right\\rangle \\,\\backsimeq\\, A\\exp\\left(-t/\\tau\\right)+B$\", fontsize=18)\n",
    "\n",
    "plt.legend(title=f\"# of trials = {NoT}, nbeads = 100\") # handles=legend_elements\n",
    "plt.xlim(min(t), max(t))\n",
    "plt.ylim(min(Rg_ave), max(Rg_ave))\n",
    "\n",
    "plt.gca().spines['right'].set_visible(False)\n",
    "plt.gca().spines['top'].set_visible(False)\n",
    "plt.tight_layout()\n",
    "#plt.savefig(\"rg_vs_t.pdf\")\n",
    "plt.show()\n",
    "\n",
    "print('   τ =', '%0.18f' % popt[0], '±', \"%.18f\" % pcov[0,0]**0.5) #2ND HALF IS FIT UNCERTAINTY\n",
    "print('   A =', \"%0.18f\" % popt[1], '±', \"%.18f\" % pcov[1,1]**0.5)\n",
    "print('   B =', \"%0.18f\" % popt[2], '±', \"%.18f\" % pcov[2,2]**0.5)\n",
