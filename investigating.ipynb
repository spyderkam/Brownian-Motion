    "plt.xlabel(r\"time\", fontsize=20)\n",
    "plt.ylabel(r\"$\\left\\langle{R_\\mathrm{ee}}\\right\\rangle \\,\\backsimeq\\, A\\exp\\left(-t/\\tau\\right)+B$\", fontsize=18)\n",
    "\n",
    "plt.legend(title=f\"# of trials = {NoT}\")#, nbeads = 30\") # handles=legend_elements\n",
